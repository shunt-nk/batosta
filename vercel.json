{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "rewrites": [
    { "source": "/includes/(.*)",  "destination": "/404" },
    { "source": "/assets/:path*",  "destination": "/src/assets/:path*" },
    { "source": "/styles/:path*",  "destination": "/src/styles/:path*" },
    { "source": "/js/:path*",      "destination": "/src/js/:path*" },
    { "source": "/:file.php",      "destination": "/api/:file.php" },
    { "source": "/",               "destination": "/api/index.php" }
  ]
}
