# Database connection for Vercel + Supabase (set in Vercel project settings)
# Supabaseの接続情報: Project Settings → Database → Connection string (URI) から取得
DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password
DB_SSLMODE=require

# Local Docker (docker-compose.yml で自動設定されるので不要)
# DB_HOST=db
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=password
# DB_SSLMODE=disable
